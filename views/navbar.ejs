<div class="d-flex">
    <!-- 🔹 Sidebar -->
    <div class="sidebar p-3">
        <% if (user) { %>
        <a href="/" class="sidebar-link nav-link my-text text-white font-weight-bold px-3" style="margin-top: 16px;">🏠 Home</a>
        <a href="/dashboard" class="sidebar-link nav-link my-text text-white font-weight-bold px-3">📊 Dashboard</a>
        <a href="/manage" class="sidebar-link nav-link my-text text-white font-weight-bold px-3">📦 จัดการสินค้า</a>
        <a href="/sales/new" class="sidebar-link nav-link my-text text-white font-weight-bold px-3">💰 ขายสินค้า</a>
        <a href="/members" class="sidebar-link nav-link my-text text-white font-weight-bold px-3">👥 สมาชิก</a>
        <% } %>
